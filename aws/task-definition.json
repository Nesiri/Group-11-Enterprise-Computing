{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "react-cicd-task",
    "containerDefinitions": [
        {
            "name": "react-cicd",
            "image": "871749382674.dkr.ecr.us-east-2.amazonaws.com/react-cicd:latest",
            "portMappings": [
                {
                    "name": "ngnix-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::871749382674:role/ecsTaskExecutionRole"
}